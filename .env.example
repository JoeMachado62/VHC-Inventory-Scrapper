# VCH API connection
VCH_API_BASE_URL=https://your-vch-server.com/v1
VCH_SERVICE_TOKEN=replace-me

# Browser automation
CHROME_DEBUG_HOST=127.0.0.1
CHROME_DEBUG_PORT=9222

# Scraper behavior
SYNC_INTERVAL_SECONDS=3600
SYNC_WINDOW_START_HOUR_EASTERN=9
SYNC_WINDOW_END_HOUR_EASTERN=21
DEEP_SCRAPE_POLL_INTERVAL_SECONDS=30
DEEP_SCRAPE_MAX_WORKERS=4
NOT_FOUND_CONFIRM_ATTEMPTS=3
IMS_REFRESH_START_HOUR_EASTERN=16
IMS_REFRESH_END_HOUR_EASTERN=17
SCRAPER_NODE_ID=joes-desktop
SCRAPER_VERSION=0.1.0
EXPORT_DIR=./exports
ARTIFACT_DIR=./artifacts

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/ove_scraper.log

# OVE browser detail capture
OVE_BASE_URL=https://www.ove.com
OVE_LISTINGS_URL=https://www.ove.com
OVE_SOURCE_PLATFORM=manheim
OVE_EAST_SEARCHES=East Hub 2015 - 2021|East Hub 2022|East Hub 2023|East Hub 2024|East Hub 2025-2026
OVE_WEST_SEARCHES=West Hub 2015-2023|West Hub 2024-2026
OVE_SEARCH_INPUT_SELECTOR=input[type='search'], input[placeholder*='VIN'], input[name*='search']
OVE_RESULT_LINK_SELECTOR=a[href*='/vehicle/'], a[href*='/listing/']
OVE_EXPORT_BUTTON_SELECTOR=button:has-text('Export'), a:has-text('Export')
OVE_SAVE_SEARCH_LINK_SELECTOR=a:has-text('{search_name}'), button:has-text('{search_name}')
OVE_SECTION_ROOT_SELECTOR=main, [role='main'], body
